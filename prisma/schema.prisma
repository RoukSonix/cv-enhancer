generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts           Account[]
  roasts             Roast[]
  templatePurchases  TemplatePurchase[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Roast {
  id              String    @id              // nanoid, 12 chars
  resumeText      String                     // original resume text
  resumeHash      String                     // SHA-256 hash for dedup
  tier            String    @default("free") // "free" or "paid"
  result          Json                       // full RoastResult JSON
  overallScore    Int                        // denormalized for queries
  createdAt       DateTime  @default(now())

  // Sprint 4: Payment fields
  paid            Boolean   @default(false)  // true after successful payment
  stripeSessionId String?   @unique          // Stripe Checkout session ID
  paidAt          DateTime?                  // when payment was confirmed
  creditId        String?                    // links to Credit if upgraded via bundle

  // Sprint 5: Email capture
  email           String?                    // user's email (required for free, optional for paid)
  marketingOptIn  Boolean   @default(false)  // true if user checked "Send me resume tips"

  // Sprint 9: Rating
  rating          Int?                       // 1 = thumbs up, -1 = thumbs down, null = no rating

  // Sprint 10: Auth link
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])

  @@index([resumeHash])
  @@index([createdAt])
  @@index([email])
  @@index([userId])
}

model Credit {
  id              String    @id @default(cuid())
  bundleToken     String                    // shared token for all credits in a bundle
  stripeSessionId String                    // Stripe Checkout session that created this
  roastId         String?                   // null = unused, set when redeemed
  usedAt          DateTime?                 // when the credit was consumed
  createdAt       DateTime  @default(now())

  @@index([bundleToken])
  @@index([stripeSessionId])
}

model TemplatePurchase {
  id              String    @id @default(cuid())
  email           String
  stripeSessionId String    @unique
  paidAt          DateTime  @default(now())
  downloadCount   Int       @default(0)
  lastDownloadAt  DateTime?

  userId          String?
  user            User?     @relation(fields: [userId], references: [id])

  @@index([email])
  @@index([userId])
}
