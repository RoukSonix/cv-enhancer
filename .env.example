# OpenRouter API configuration
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# AI model to use for resume analysis
# Default: deepseek/deepseek-chat-v3-0324:free (free tier)
# Recommended: minimax/minimax-m2.5
# Full list: https://openrouter.ai/models
OPENROUTER_MODEL=minimax/minimax-m2.5

# Database (PostgreSQL)
# Docker Compose sets this automatically; only needed for local dev without Docker
DATABASE_URL=postgresql://cvenhancer:cvenhancer@localhost:5432/cvenhancer

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_SINGLE=price_...
STRIPE_PRICE_BUNDLE=price_...
STRIPE_PRICE_TEMPLATES=price_...  # Stripe Price ID for template pack ($29)
STRIPE_PRICE_REWRITE_BASIC=price_...     # $99 Basic Rewrite
STRIPE_PRICE_REWRITE_PREMIUM=price_...   # $199 Premium Rewrite

# Base URL for OG image meta tags (social sharing)
NEXT_PUBLIC_BASE_URL=https://resumeroaster.com

# Auth.js v5 (Sprint 10)
AUTH_URL=http://localhost:3000
AUTH_SECRET=  # Generate with: npx auth secret

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend (magic link emails)
RESEND_API_KEY=

# Admin token (for script/API access to admin endpoints)
ADMIN_TOKEN=

# Admin email (for rewrite order notifications)
ADMIN_EMAIL=admin@resumeroaster.com
